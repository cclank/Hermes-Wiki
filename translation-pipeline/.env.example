# Google Cloud Configuration
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
GCS_BUCKET_NAME=hermes-wiki-translations

# Claude API Configuration
CLAUDE_API_KEY=sk-ant-your-api-key-here

# Service Configuration
PORT=8080
FLASK_ENV=production
LOG_LEVEL=INFO

# GitHub Configuration (optional, for repo translation)
GITHUB_TOKEN=ghp_your-github-token-here

# Translation Settings
MAX_WORKERS=5
BATCH_SIZE=10
TRANSLATION_MODEL=claude-3-5-sonnet-20241022
MAX_TOKENS=4096

# Local Mode (set to true to run without Cloud Run)
LOCAL_MODE=false
LOCAL_STORAGE_PATH=./translations
